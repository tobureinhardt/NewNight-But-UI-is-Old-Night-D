if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
    Night.Mobile = true
    if Camera then
        if 0.4 >= (Camera.ViewportSize.X / 1000) - 0.1 then
            Night.Scale = 0.4
        else
            Night.Scale = (Camera.ViewportSize.X / 1000) - 0.2
        end
